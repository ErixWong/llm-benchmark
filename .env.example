# API Configuration
API_BASE_URL=https://api.example.com/v1
API_KEY=your-api-key-here
API_MODEL=gpt-3.5-turbo

# Test Configuration
DEFAULT_CONCURRENCY=4
DEFAULT_TIMEOUT=30000

# Token Speed Test Configuration
# 采样轮数：并发数 × 轮数 = 总采样数
# 例如：并发4，轮数5，则总采样数=20
ROUNDS=5
MAX_OUTPUT_TOKENS=30000

# Concurrency Mode: 'batch' (wait for all requests in batch) or 'pipeline' (start new request when one completes)
CONCURRENCY_MODE=pipeline

# Sample Configuration (for large context testing)
# 每次请求随机抽取多少个8k样本文件
# SAMPLE_COUNT=0 时使用默认简单prompt
SAMPLE_COUNT=4

# Report Configuration
REPORT_OUTPUT_DIR=./results
REPORT_FORMAT=json